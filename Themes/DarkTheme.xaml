<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Semantic brushes ───────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="App.Window.Background"   Color="#FF1E1E28"/>
    <SolidColorBrush x:Key="App.Foreground"          Color="#FFE2E2EA"/>
    <SolidColorBrush x:Key="App.Subtle"              Color="#FF909098"/>
    <SolidColorBrush x:Key="App.Border"              Color="#FF3A3A48"/>
    <SolidColorBrush x:Key="App.Input.Background"    Color="#FF2A2A36"/>
    <SolidColorBrush x:Key="App.Input.Foreground"    Color="#FFE2E2EA"/>
    <SolidColorBrush x:Key="App.Accent"              Color="#FF3A9EFF"/>

    <SolidColorBrush x:Key="App.Drop.Background"     Color="#FF252530"/>
    <SolidColorBrush x:Key="App.Drop.Border"         Color="#FF3A9EFF"/>
    <SolidColorBrush x:Key="App.Drop.Unloaded"       Color="#FF606068"/>

    <SolidColorBrush x:Key="App.Grid.Background"     Color="#FF1E1E28"/>
    <SolidColorBrush x:Key="App.Grid.Row"            Color="#FF252530"/>
    <SolidColorBrush x:Key="App.Grid.Row.Alt"        Color="#FF1E1E28"/>
    <SolidColorBrush x:Key="App.Grid.Header"         Color="#FF2A2A38"/>
    <SolidColorBrush x:Key="App.Grid.Lines"          Color="#FF363644"/>

    <!-- ── Waveform ───────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="Wave.Background"         Color="#FF12141C"/>
    <SolidColorBrush x:Key="Wave.Bar.Hi"             Color="#FF0082F0"/>
    <SolidColorBrush x:Key="Wave.Bar.Lo"             Color="#FF00509A"/>
    <SolidColorBrush x:Key="Wave.Grid"               Color="#FF222230"/>
    <SolidColorBrush x:Key="Wave.Ruler.Background"   Color="#FF0C0E14"/>
    <SolidColorBrush x:Key="Wave.Ruler.Foreground"   Color="#FF6E7890"/>
    <SolidColorBrush x:Key="Wave.Marker"             Color="#FFFFB820"/>
    <Color           x:Key="Wave.Exclude.Color">#960A0A0A</Color>
    <SolidColorBrush x:Key="Wave.Hint"               Color="#FF606068"/>

    <!-- ── Control styles ────────────────────────────────────────────────── -->
    <Style TargetType="Window">
        <Setter Property="Background" Value="{DynamicResource App.Window.Background}"/>
    </Style>
    <Style TargetType="Menu">
        <Setter Property="Background" Value="#FF252530"/>
        <Setter Property="Foreground" Value="{DynamicResource App.Foreground}"/>
    </Style>
    <Style TargetType="MenuItem">
        <Setter Property="Background" Value="#FF252530"/>
        <Setter Property="Foreground" Value="{DynamicResource App.Foreground}"/>
    </Style>
    <Style TargetType="StatusBar">
        <Setter Property="Background" Value="#FF1A1A24"/>
        <Setter Property="Foreground" Value="{DynamicResource App.Subtle}"/>
    </Style>
    <Style TargetType="GroupBox">
        <Setter Property="Foreground"   Value="{DynamicResource App.Foreground}"/>
        <Setter Property="BorderBrush"  Value="{DynamicResource App.Border}"/>
    </Style>
    <Style TargetType="Label">
        <Setter Property="Foreground" Value="{DynamicResource App.Foreground}"/>
    </Style>
    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource App.Foreground}"/>
    </Style>
    <Style TargetType="TextBox">
        <Setter Property="Background"   Value="{DynamicResource App.Input.Background}"/>
        <Setter Property="Foreground"   Value="{DynamicResource App.Input.Foreground}"/>
        <Setter Property="CaretBrush"   Value="{DynamicResource App.Input.Foreground}"/>
        <Setter Property="BorderBrush"  Value="{DynamicResource App.Border}"/>
    </Style>
    <Style TargetType="Button">
        <Setter Property="Background"  Value="#FF2E2E3C"/>
        <Setter Property="Foreground"  Value="{DynamicResource App.Foreground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource App.Border}"/>
        <Setter Property="Padding"     Value="10,4"/>
        <Setter Property="MinHeight"   Value="26"/>
    </Style>
    <Style TargetType="TabControl">
        <Setter Property="Background"  Value="{DynamicResource App.Window.Background}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource App.Border}"/>
    </Style>
    <Style TargetType="TabItem">
        <Setter Property="Background"  Value="#FF252530"/>
        <Setter Property="Foreground"  Value="{DynamicResource App.Foreground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource App.Border}"/>
    </Style>
    <Style TargetType="DataGrid">
        <Setter Property="Background"               Value="{DynamicResource App.Grid.Background}"/>
        <Setter Property="Foreground"               Value="{DynamicResource App.Foreground}"/>
        <Setter Property="RowBackground"            Value="{DynamicResource App.Grid.Row}"/>
        <Setter Property="AlternatingRowBackground" Value="{DynamicResource App.Grid.Row.Alt}"/>
        <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource App.Grid.Lines}"/>
        <Setter Property="VerticalGridLinesBrush"   Value="Transparent"/>
        <Setter Property="GridLinesVisibility"      Value="Horizontal"/>
        <Setter Property="BorderBrush"              Value="{DynamicResource App.Border}"/>
    </Style>
    <Style TargetType="DataGridRow">
        <Setter Property="Background" Value="{DynamicResource App.Grid.Row}"/>
        <Setter Property="Foreground" Value="{DynamicResource App.Foreground}"/>
    </Style>
    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background"  Value="{DynamicResource App.Grid.Header}"/>
        <Setter Property="Foreground"  Value="{DynamicResource App.Foreground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource App.Border}"/>
        <Setter Property="Padding"     Value="6,4"/>
    </Style>
    <Style TargetType="DataGridCell">
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground"      Value="{DynamicResource App.Foreground}"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource App.Accent}"/>
                <Setter Property="Foreground" Value="White"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="#FF252530"/>
    </Style>
    <Style TargetType="ProgressBar">
        <Setter Property="Background" Value="#FF2E2E3C"/>
        <Setter Property="Foreground" Value="{DynamicResource App.Accent}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource App.Border}"/>
    </Style>
</ResourceDictionary>

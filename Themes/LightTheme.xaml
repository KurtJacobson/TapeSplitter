<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Semantic brushes ───────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="App.Window.Background"   Color="{x:Static SystemColors.ControlColor}"/>
    <SolidColorBrush x:Key="App.Foreground"          Color="{x:Static SystemColors.ControlTextColor}"/>
    <SolidColorBrush x:Key="App.Subtle"              Color="{x:Static SystemColors.GrayTextColor}"/>
    <SolidColorBrush x:Key="App.Border"              Color="{x:Static SystemColors.ControlDarkColor}"/>
    <SolidColorBrush x:Key="App.Input.Background"    Color="{x:Static SystemColors.WindowColor}"/>
    <SolidColorBrush x:Key="App.Input.Foreground"    Color="{x:Static SystemColors.WindowTextColor}"/>
    <SolidColorBrush x:Key="App.Accent"              Color="{x:Static SystemColors.HotTrackColor}"/>

    <SolidColorBrush x:Key="App.Drop.Background"     Color="{x:Static SystemColors.ControlLightColor}"/>
    <SolidColorBrush x:Key="App.Drop.Border"         Color="{x:Static SystemColors.HotTrackColor}"/>
    <SolidColorBrush x:Key="App.Drop.Unloaded"       Color="{x:Static SystemColors.GrayTextColor}"/>

    <SolidColorBrush x:Key="App.Grid.Background"     Color="{x:Static SystemColors.WindowColor}"/>
    <SolidColorBrush x:Key="App.Grid.Row"            Color="{x:Static SystemColors.WindowColor}"/>
    <SolidColorBrush x:Key="App.Grid.Row.Alt"        Color="#F2F5F8"/>
    <SolidColorBrush x:Key="App.Grid.Header"         Color="{x:Static SystemColors.ControlColor}"/>
    <SolidColorBrush x:Key="App.Grid.Lines"          Color="#DCDCDC"/>

    <!-- ── Waveform colors (light theme) ────────────────────────────────── -->
    <SolidColorBrush x:Key="Wave.Background"         Color="#EEF2F7"/>
    <SolidColorBrush x:Key="Wave.Bar.Hi"             Color="#1565C0"/>
    <SolidColorBrush x:Key="Wave.Bar.Lo"             Color="#90CAF9"/>
    <SolidColorBrush x:Key="Wave.Grid"               Color="#D0DAE6"/>
    <SolidColorBrush x:Key="Wave.Ruler.Background"   Color="#DDE4EE"/>
    <SolidColorBrush x:Key="Wave.Ruler.Foreground"   Color="#546E7A"/>
    <SolidColorBrush x:Key="Wave.Marker"             Color="#E65100"/>
    <Color           x:Key="Wave.Exclude.Color">#96C8C8C8</Color>
    <SolidColorBrush x:Key="Wave.Hint"               Color="{x:Static SystemColors.GrayTextColor}"/>

    <!-- ── Control styles ────────────────────────────────────────────────── -->
    <Style TargetType="GroupBox">
        <Setter Property="Foreground" Value="{DynamicResource App.Foreground}"/>
    </Style>
    <Style TargetType="Label">
        <Setter Property="Foreground" Value="{DynamicResource App.Foreground}"/>
    </Style>
    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource App.Foreground}"/>
    </Style>
    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{DynamicResource App.Input.Background}"/>
        <Setter Property="Foreground" Value="{DynamicResource App.Input.Foreground}"/>
        <Setter Property="CaretBrush" Value="{DynamicResource App.Input.Foreground}"/>
    </Style>
    <Style TargetType="DataGrid">
        <Setter Property="Background"            Value="{DynamicResource App.Grid.Background}"/>
        <Setter Property="Foreground"            Value="{DynamicResource App.Foreground}"/>
        <Setter Property="RowBackground"         Value="{DynamicResource App.Grid.Row}"/>
        <Setter Property="AlternatingRowBackground" Value="{DynamicResource App.Grid.Row.Alt}"/>
        <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource App.Grid.Lines}"/>
        <Setter Property="VerticalGridLinesBrush"   Value="Transparent"/>
        <Setter Property="GridLinesVisibility"   Value="Horizontal"/>
        <Setter Property="BorderBrush"           Value="{DynamicResource App.Border}"/>
    </Style>
    <Style TargetType="DataGridRow">
        <Setter Property="Foreground" Value="{DynamicResource App.Foreground}"/>
    </Style>
    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{DynamicResource App.Grid.Header}"/>
        <Setter Property="Foreground" Value="{DynamicResource App.Foreground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource App.Border}"/>
        <Setter Property="Padding"    Value="6,4"/>
    </Style>
    <Style TargetType="DataGridCell">
        <Setter Property="BorderThickness" Value="0"/>
    </Style>
</ResourceDictionary>
